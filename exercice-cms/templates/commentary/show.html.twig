{% extends 'base.html.twig' %}

{% block title %}Commentary{% endblock %}

{% block body %}
    <h1>Commentary</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ commentary.id }}</td>
            </tr>
            <tr>
                <th>Content</th>
                <td>{{ commentary.content }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ commentary.createdAt ? commentary.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>IsApprouved</th>
                <td>{{ commentary.isApprouved ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>NameAuthor</th>
                <td>{{ commentary.nameAuthor }}</td>
            </tr>
            <tr>
                <th>EmailAuthor</th>
                <td>{{ commentary.emailAuthor }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_commentary_index') }}">back to list</a>

    <a href="{{ path('app_commentary_edit', {'id': commentary.id}) }}">edit</a>

    {{ include('commentary/_delete_form.html.twig') }}
{% endblock %}
