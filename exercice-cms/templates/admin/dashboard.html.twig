{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Tableau de bord{% endblock %}

{% block main %}
<div class="row g-4 mb-5">

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#0f6efd,#0b5ed7);
                            display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;flex-shrink:0;">
                    <i class="fa fa-newspaper"></i>
                </div>
                <div>
                    <div style="font-size:2rem;font-weight:800;line-height:1;color:#0b254c;">{{ total_articles }}</div>
                    <div style="font-size:.8rem;color:#6c757d;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Articles total</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#198754,#146c43);
                            display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;flex-shrink:0;">
                    <i class="fa fa-check-circle"></i>
                </div>
                <div>
                    <div style="font-size:2rem;font-weight:800;line-height:1;color:#0b254c;">{{ published_articles }}</div>
                    <div style="font-size:.8rem;color:#6c757d;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Articles publiés</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#fd7e14,#e96b02);
                            display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;flex-shrink:0;">
                    <i class="fa fa-comments"></i>
                </div>
                <div>
                    <div style="font-size:2rem;font-weight:800;line-height:1;color:#0b254c;">{{ pending_comments }}</div>
                    <div style="font-size:.8rem;color:#6c757d;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Commentaires en attente</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div style="width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#6f42c1,#5a32a3);
                            display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;flex-shrink:0;">
                    <i class="fa fa-users"></i>
                </div>
                <div>
                    <div style="font-size:2rem;font-weight:800;line-height:1;color:#0b254c;">{{ total_users }}</div>
                    <div style="font-size:.8rem;color:#6c757d;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Utilisateurs</div>
                </div>
            </div>
        </div>
    </div>
</div>

{% if pending_comments > 0 %}
<div class="alert alert-warning d-flex align-items-center gap-2">
    <i class="fa fa-exclamation-triangle"></i>
    <span>
        <strong>{{ pending_comments }} commentaire{{ pending_comments > 1 ? 's' : '' }} en attente</strong> de modération.
        <a href="{{ ea_url().setController('App\\Controller\\Admin\\CommentaryCrudController').setAction('index').generateUrl() }}"
           class="alert-link">Modérer maintenant →</a>
    </span>
</div>
{% endif %}

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom" style="font-weight:700;color:#0b254c;">
                <i class="fa fa-bolt me-2 text-primary"></i>Actions rapides
            </div>
            <div class="card-body d-flex flex-wrap gap-2">
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ArticleCrudController').setAction('new').generateUrl() }}"
                   class="btn btn-primary btn-sm">
                    <i class="fa fa-plus me-1"></i>Nouvel article
                </a>
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\PageCrudController').setAction('new').generateUrl() }}"
                   class="btn btn-outline-primary btn-sm">
                    <i class="fa fa-plus me-1"></i>Nouvelle page
                </a>
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\GalleryCrudController').setAction('new').generateUrl() }}"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-plus me-1"></i>Nouvelle galerie
                </a>
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').setAction('new').generateUrl() }}"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-plus me-1"></i>Nouvel utilisateur
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
