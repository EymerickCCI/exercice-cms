<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}MonCMS{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{% endblock %}">

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📝</text></svg>">

    {# Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@700;800&display=swap" rel="stylesheet">

    {# Bootstrap Icons #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {# Styles inline spécifiques à la page #}
    <style>{% block page_styles %}{% endblock %}</style>
</head>

<body>

{# ══════════════════════════════════════════
   NAVBAR
══════════════════════════════════════════ #}
<header class="site-header">
    <nav class="navbar navbar-expand-lg" style="background:#0b254c; padding:.75rem 0;">
        <div class="container">

            {# Logo/Marque #}
            <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('app_home') }}"
               style="font-family:'Poppins',sans-serif; font-weight:800; font-size:1.35rem; color:#fff; text-decoration:none;">
                <span style="display:inline-flex; align-items:center; justify-content:center;
                             width:36px; height:36px; background:linear-gradient(135deg,#4fa3ff,#0f6efd);
                             border-radius:10px; font-size:1rem;">📝</span>
                Mon<span style="color:#4fa3ff;">CMS</span>
            </a>

            {# Burger #}
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false"
                    style="color:rgba(255,255,255,.8);">
                <i class="bi bi-list fs-4"></i>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                {# Liens principaux #}
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 rounded-2 {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}"
                           href="{{ path('app_home') }}"
                           style="color:rgba(255,255,255,.88); font-weight:500; font-size:.9rem;">
                           <i class="bi bi-house me-1"></i>Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 rounded-2 {% if 'app_article' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                           href="{{ path('app_article_index') }}"
                           style="color:rgba(255,255,255,.88); font-weight:500; font-size:.9rem;">
                           <i class="bi bi-newspaper me-1"></i>Blog
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 rounded-2 {% if 'app_gallery' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                           href="{{ path('app_gallery_index') }}"
                           style="color:rgba(255,255,255,.88); font-weight:500; font-size:.9rem;">
                           <i class="bi bi-images me-1"></i>Galeries
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3 py-2 rounded-2"
                           href="{{ path('app_page_index') }}"
                           style="color:rgba(255,255,255,.88); font-weight:500; font-size:.9rem;">
                           <i class="bi bi-file-earmark-text me-1"></i>Pages
                        </a>
                    </li>
                </ul>

                {# Zone droite : user / admin #}
                <div class="d-flex align-items-center gap-2">
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_article_index') }}"
                       style="font-size:.8rem; font-weight:600; padding:.45rem 1rem; background:linear-gradient(135deg,#4fa3ff,#0f6efd);
                              color:#fff; border-radius:8px; text-decoration:none; white-space:nowrap;"
                       title="Administration">
                        <i class="bi bi-shield-lock me-1"></i>Admin
                    </a>
                    {% endif %}

                    {% if is_granted('ROLE_WRITER') %}
                    <a href="{{ path('app_article_new') }}"
                       style="font-size:.8rem; font-weight:600; padding:.45rem 1rem; background:rgba(255,255,255,.1);
                              color:#fff; border:1px solid rgba(255,255,255,.25); border-radius:8px; text-decoration:none; white-space:nowrap;">
                        <i class="bi bi-plus-lg me-1"></i>Écrire
                    </a>
                    {% endif %}

                    {% if app.user %}
                    <div class="dropdown">
                        <button class="btn btn-sm d-flex align-items-center gap-2 dropdown-toggle"
                                style="background:rgba(255,255,255,.1); color:#fff; border:1px solid rgba(255,255,255,.2); border-radius:8px; font-size:.85rem;"
                                data-bs-toggle="dropdown">
                            <span style="width:28px;height:28px;border-radius:50%;background:#4fa3ff;
                                         display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;">
                                {{ app.user.userIdentifier|slice(0,1)|upper }}
                            </span>
                            <span class="d-none d-md-inline">{{ app.user.userIdentifier|slice(0,20) }}</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><h6 class="dropdown-header">{{ app.user.userIdentifier }}</h6></li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-2 text-danger"></i>Déconnexion
                                </a>
                            </li>
                        </ul>
                    </div>
                    {% else %}
                    <a href="{{ path('app_login') }}"
                       style="font-size:.85rem; font-weight:600; padding:.45rem 1rem;
                              color:rgba(255,255,255,.88); border:1px solid rgba(255,255,255,.25);
                              border-radius:8px; text-decoration:none;">
                        <i class="bi bi-person me-1"></i>Connexion
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>
</header>

{# ══════════════════════════════════════════
   FLASH MESSAGES
══════════════════════════════════════════ #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show m-0 rounded-0"
         role="alert" style="border-radius:0!important; border-top:none; border-left:none; border-right:none;">
        <div class="container d-flex align-items-center gap-2">
            {% if type == 'success' %}<i class="bi bi-check-circle-fill text-success"></i>
            {% elseif type == 'danger' or type == 'error' %}<i class="bi bi-exclamation-triangle-fill text-danger"></i>
            {% else %}<i class="bi bi-info-circle-fill text-info"></i>{% endif %}
            {{ message }}
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    {% endfor %}
{% endfor %}

{# ══════════════════════════════════════════
   CONTENU PRINCIPAL
══════════════════════════════════════════ #}
<main class="site-main">
    {% block body %}{% endblock %}
</main>

{# ══════════════════════════════════════════
   FOOTER
══════════════════════════════════════════ #}
<footer style="background:#0e1938; color:#a8b8d8; padding:3rem 0 1.5rem;">
    <div class="container">
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div style="font-family:'Poppins',sans-serif; font-weight:800; font-size:1.2rem; color:#fff; margin-bottom:.75rem;">
                    Mon<span style="color:#4fa3ff;">CMS</span>
                </div>
                <p style="font-size:.875rem; line-height:1.7; color:#8899bb;">
                    Un CMS moderne propulsé par Symfony &amp; EasyAdmin.
                </p>
            </div>
            <div class="col-md-4">
                <h6 style="color:#fff; font-weight:700; font-size:.8rem; letter-spacing:.08em; text-transform:uppercase; margin-bottom:1rem;">Navigation</h6>
                <ul class="list-unstyled mb-0" style="font-size:.875rem;">
                    <li class="mb-2"><a href="{{ path('app_home') }}" style="color:#8899bb; text-decoration:none;">Accueil</a></li>
                    <li class="mb-2"><a href="{{ path('app_article_index') }}" style="color:#8899bb; text-decoration:none;">Blog</a></li>
                    <li class="mb-2"><a href="{{ path('app_gallery_index') }}" style="color:#8899bb; text-decoration:none;">Galeries</a></li>
                    <li class="mb-2"><a href="{{ path('app_page_index') }}" style="color:#8899bb; text-decoration:none;">Pages</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 style="color:#fff; font-weight:700; font-size:.8rem; letter-spacing:.08em; text-transform:uppercase; margin-bottom:1rem;">Administration</h6>
                <ul class="list-unstyled mb-0" style="font-size:.875rem;">
                    {% if is_granted('ROLE_ADMIN') %}
                    <li class="mb-2"><a href="{{ path('app_article_index') }}" style="color:#4fa3ff; text-decoration:none;"><i class="bi bi-shield-lock me-1"></i>Tableau de bord</a></li>
                    {% endif %}
                    {% if app.user %}
                    <li class="mb-2"><a href="{{ path('app_logout') }}" style="color:#8899bb; text-decoration:none;">Déconnexion</a></li>
                    {% else %}
                    <li class="mb-2"><a href="{{ path('app_login') }}" style="color:#8899bb; text-decoration:none;">Connexion</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>
        <div style="border-top:1px solid rgba(255,255,255,.08); padding-top:1.25rem; text-align:center; font-size:.8rem; color:#556880;">
            &copy; {{ "now"|date('Y') }} MonCMS — Propulsé par Symfony {{ constant('Symfony\\Component\\HttpKernel\\Kernel::VERSION') }}
        </div>
    </div>
</footer>

    {% block javascripts %}
        <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>

        <script>
            CKEDITOR.replace('article_content', {
                height: 300,
                uiColor: '#ffffff',
                toolbar: 'Full'
            });
        </script>

        {{ encore_entry_script_tags('app') }}
    {% endblock %}

</body>
</html>
