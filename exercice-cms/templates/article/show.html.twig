{% extends 'base.html.twig' %}

{% block title %}{{ article.title }} — {{ site_name|default('MonCMS') }}{% endblock %}
{% block meta_description %}{{ article.metaDescription ?: article.title }}{% endblock %}

{% block page_styles %}
.article-show-wrapper {
    background: var(--color-white);
    border-radius: var(--border-radius);
    box-shadow: 0 8px 24px rgba(20, 32, 50, 0.08);
    overflow: hidden;
    margin-bottom: 2rem;
}

.article-header {
    background: linear-gradient(135deg, #0b254c 0%, #1a3a5c 100%);
    color: white;
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
}

.article-header::before {
    content: '';
    position: absolute;
    top: -50px;
    right: -100px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    border-radius: 50%;
}

.article-header-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
}

.article-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: white;
}

.article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    font-size: 0.9rem;
    opacity: 0.9;
}

.article-meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.article-meta-item i {
    font-size: 0.8em;
}

.article-featured-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    margin-bottom: 2rem;
    border-radius: var(--border-radius);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
}

.article-content-wrapper {
    padding: 2rem;
}

.article-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #2d3748;
    margin-bottom: 2rem;
}

.article-content h1,
.article-content h2,
.article-content h3,
.article-content h4,
.article-content h5,
.article-content h6 {
    color: #0b254c;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
}

.article-content h1 { font-size: 2rem; }
.article-content h2 { font-size: 1.75rem; }
.article-content h3 { font-size: 1.5rem; }
.article-content h4 { font-size: 1.25rem; }

.article-content p {
    margin-bottom: 1.5rem;
}

.article-content ul,
.article-content ol {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
}

.article-content li {
    margin-bottom: 0.5rem;
}

.article-content blockquote {
    border-left: 4px solid #0f6efd;
    padding-left: 1rem;
    margin: 2rem 0;
    font-style: italic;
    color: #495057;
}

.article-content img {
    max-width: 100%;
    height: auto;
    border-radius: var(--border-radius);
    margin: 1rem 0;
}

.article-sidebar {
    background: var(--color-surface);
    border-left: 1px solid var(--color-border);
    padding: 2rem;
}

.article-info-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.article-info-card h4 {
    font-size: 1rem;
    color: #0f6efd;
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.article-info-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
}

.article-info-item:last-child {
    border-bottom: none;
}

.article-info-label {
    font-weight: 600;
    color: #495057;
    font-size: 0.9rem;
}

.article-info-value {
    color: #0b254c;
    font-weight: 500;
}

.article-status-published {
    color: #198754;
    font-weight: 700;
}

.article-status-draft {
    color: #fd7e14;
    font-weight: 700;
}

.article-actions {
    background: white;
    border-top: 1px solid var(--color-border);
    padding: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.article-actions .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 0.65rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all var(--transition);
}

.article-actions .btn-primary {
    background: linear-gradient(135deg, #0f6efd, #0b5ed7);
    border: none;
}

.article-actions .btn-primary:hover {
    background: linear-gradient(135deg, #0b5ed7, #094db2);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(15, 78, 194, 0.3);
}

.article-actions .btn-outline-secondary {
    border-color: #0f6efd;
    color: #0f6efd;
}

.article-actions .btn-outline-secondary:hover {
    background: #0f6efd;
    color: white;
}

.article-actions .btn-outline-danger {
    border-color: #dc3545;
    color: #dc3545;
}

.article-actions .btn-outline-danger:hover {
    background: #dc3545;
    color: white;
}

@media (max-width: 768px) {
    .article-header {
        padding: 2rem 1.5rem;
    }

    .article-title {
        font-size: 2rem;
    }

    .article-content-wrapper,
    .article-sidebar {
        padding: 1.5rem;
    }

    .article-sidebar {
        border-left: none;
        border-top: 1px solid var(--color-border);
        margin-top: 2rem;
    }

    .article-actions {
        padding: 1.5rem;
        flex-direction: column;
    }

    .article-actions .btn {
        justify-content: center;
    }
}
{% endblock %}

{% block body %}
<div class="article-show-wrapper">
    {# ══ ARTICLE HEADER ══ #}
    <header class="article-header">
        <div class="container">
            <div class="article-header-content">
                <h1 class="article-title">{{ article.title }}</h1>
                <div class="article-meta">
                    <div class="article-meta-item">
                        <i class="bi bi-calendar"></i>
                        <span>{{ article.createdAt|date('d M Y') }}</span>
                    </div>
                    {% if article.category %}
                    <div class="article-meta-item">
                        <i class="bi bi-tag"></i>
                        <a href="{{ path('app_article_index', {category: article.category.slug}) }}"
                           class="tag-pill">{{ article.category.name }}</a>
                    </div>
                    {% endif %}
                    <div class="article-meta-item">
                        <i class="bi bi-eye"></i>
                        <span class="article-status-{{ article.isPublished ? 'published' : 'draft' }}">
                            {{ article.isPublished ? 'Publié' : 'Brouillon' }}
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    {# ══ ARTICLE CONTENT ══ #}
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                {# Image mise en avant #}
                {% if article.featuredImage %}
                <img src="/uploads/articles/{{ article.featuredImage }}"
                     alt="{{ article.title }}"
                     class="article-featured-image">
                {% endif %}

                <div class="article-content-wrapper">
                    <div class="article-content">
                        {# Contenu HTML sécurisé - utilisation de |raw avec précaution #}
                        {{ article.content|raw }}
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <aside class="article-sidebar">
                    {# Informations de l'article #}
                    <div class="article-info-card">
                        <h4>Informations</h4>
                        <div class="article-info-item">
                            <span class="article-info-label">ID</span>
                            <span class="article-info-value">#{{ article.id }}</span>
                        </div>
                        <div class="article-info-item">
                            <span class="article-info-label">Slug</span>
                            <span class="article-info-value">{{ article.slug }}</span>
                        </div>
                        <div class="article-info-item">
                            <span class="article-info-label">Créé le</span>
                            <span class="article-info-value">{{ article.createdAt|date('d/m/Y H:i') }}</span>
                        </div>
                        {% if article.updatedAt %}
                        <div class="article-info-item">
                            <span class="article-info-label">Modifié le</span>
                            <span class="article-info-value">{{ article.updatedAt|date('d/m/Y H:i') }}</span>
                        </div>
                        {% endif %}
                        <div class="article-info-item">
                            <span class="article-info-label">Statut</span>
                            <span class="article-info-value article-status-{{ article.isPublished ? 'published' : 'draft' }}">
                                {{ article.isPublished ? 'Publié' : 'Brouillon' }}
                            </span>
                        </div>
                    </div>

                    {# Tags #}
                    {% if article.tags is not empty %}
                    <div class="article-info-card">
                        <h4>Tags</h4>
                        <div class="d-flex flex-wrap gap-2">
                            {% for tag in article.tags %}
                            <a href="{{ path('app_tag_show', {id: tag.id}) }}"
                               class="tag-pill">{{ tag.name }}</a>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}

                    {# Catégorie détaillée #}
                    {% if article.category %}
                    <div class="article-info-card">
                        <h4>Catégorie</h4>
                        <a href="{{ path('app_article_index', {category: article.category.slug}) }}"
                           class="tag-pill tag-pill-large">{{ article.category.name }}</a>
                    </div>
                    {% endif %}
                </aside>
            </div>
        </div>
    </div>

    {# ══ ACTIONS ══ #}
    <div class="article-actions">
        <div class="container">
            <a href="{{ path('app_article_index') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Retour à la liste
            </a>
            <a href="{{ path('app_article_edit', {id: article.id}) }}" class="btn btn-primary">
                <i class="bi bi-pencil"></i>
                Modifier
            </a>
            {{ include('article/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
