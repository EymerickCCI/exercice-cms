{% extends 'base.html.twig' %}

{% block title %}{{ article.title }} — MonCMS{% endblock %}
{% block meta_description %}{{ article.metaDescription ?: article.content|striptags|slice(0,155) }}{% endblock %}

{% block body %}

{# ── HEADER ARTICLE ── #}
<section style="background:linear-gradient(135deg,#0b254c 0%,#1a3a5c 100%); padding:4rem 0 3rem; color:#fff; position:relative; overflow:hidden;">
    <div style="position:absolute; top:-80px; right:-120px; width:300px; height:300px;
                background:radial-gradient(circle,rgba(79,163,255,.15) 0%,transparent 70%); border-radius:50%; pointer-events:none;"></div>
    <div class="container" style="position:relative; z-index:1;">

        {# Breadcrumb #}
        <nav aria-label="breadcrumb" style="margin-bottom:1.25rem;">
            <ol class="breadcrumb mb-0" style="font-size:.8rem; opacity:.7;">
                <li class="breadcrumb-item"><a href="{{ path('app_home') }}" style="color:rgba(255,255,255,.7);">Accueil</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_article_index') }}" style="color:rgba(255,255,255,.7);">Blog</a></li>
                {% if article.category %}
                <li class="breadcrumb-item">
                    <a href="{{ path('app_article_index', {category: article.category.slug}) }}" style="color:rgba(255,255,255,.7);">
                        {{ article.category.name }}
                    </a>
                </li>
                {% endif %}
                <li class="breadcrumb-item active" style="color:rgba(255,255,255,.9);">{{ article.title|slice(0,40) }}…</li>
            </ol>
        </nav>

        {# Catégorie badge #}
        {% if article.category %}
        <a href="{{ path('app_article_index', {category: article.category.slug}) }}"
           style="display:inline-block; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em;
                  padding:.3rem .85rem; background:rgba(79,163,255,.25); color:#90c8ff; border-radius:20px;
                  text-decoration:none; margin-bottom:1.25rem; border:1px solid rgba(79,163,255,.4);">
            {{ article.category.name }}
        </a>
        {% endif %}

        <h1 style="font-family:'Poppins',sans-serif; font-weight:800; font-size:clamp(1.75rem,4vw,3rem);
                   line-height:1.15; margin-bottom:1.25rem; max-width:820px;">
            {{ article.title }}
        </h1>

        <div style="display:flex; flex-wrap:wrap; gap:1.25rem; align-items:center; font-size:.85rem; opacity:.85;">
            <span><i class="bi bi-calendar3 me-1"></i>{{ article.createdAt|date('d MMMM Y') }}</span>
            {% if article.author %}
            <span><i class="bi bi-person me-1"></i>{{ article.author.firstname ?? article.author.email }}</span>
            {% endif %}
            {% if not article.isPublished %}
            <span style="background:rgba(253,126,20,.25); color:#fd7e14; padding:.2rem .7rem; border-radius:20px; font-weight:700; font-size:.75rem;">
                <i class="bi bi-eye-slash me-1"></i>Brouillon
            </span>
            {% endif %}
        </div>
    </div>
</section>

{# ── CORPS ── #}
<section class="py-5">
    <div class="container">
        <div class="row">

            {# Contenu principal #}
            <div class="col-lg-8">

                {# Image mise en avant #}
                {% if article.featuredImage %}
                <div style="margin-bottom:2.5rem; border-radius:16px; overflow:hidden; box-shadow:0 8px 32px rgba(0,0,0,.12);">
                    <img src="/uploads/articles/{{ article.featuredImage }}"
                         alt="{{ article.title }}"
                         style="width:100%; max-height:480px; object-fit:cover; display:block;">
                </div>
                {% endif %}

                {# Contenu WYSIWYG #}
                <div style="font-size:1.05rem; line-height:1.85; color:#2d3748;">
                    {{ article.content|raw }}
                </div>

                {# Tags #}
                {% if article.tags is not empty %}
                <div style="margin-top:2.5rem; padding-top:1.5rem; border-top:1px solid #e7eaf3;">
                    <span style="font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#6c757d; margin-right:.5rem;">
                        <i class="bi bi-tag me-1"></i>Tags :
                    </span>
                    {% for tag in article.tags %}
                    <a href="{{ path('app_article_index', {tag: tag.id}) }}"
                       style="display:inline-block; font-size:.8rem; padding:.25rem .7rem; margin:.15rem;
                              background:#f0f4ff; color:#0f6efd; border-radius:20px; text-decoration:none;
                              border:1px solid #d0e0ff; font-weight:500;">
                        {{ tag.name }}
                    </a>
                    {% endfor %}
                </div>
                {% endif %}

                {# Commentaires approuvés #}
                {% set approved = article.commentaries|filter(c => c.isApprouved) %}
                {% if approved|length > 0 %}
                <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid #e7eaf3;">
                    <h3 style="font-size:1.1rem; font-weight:700; color:#0b254c; margin-bottom:1.5rem;">
                        <i class="bi bi-chat-dots me-2" style="color:#0f6efd;"></i>
                        {{ approved|length }} commentaire{{ approved|length > 1 ? 's' : '' }}
                    </h3>
                    {% for comment in approved %}
                    <div style="background:#f9fafb; border:1px solid #e7eaf3; border-radius:12px; padding:1.25rem; margin-bottom:1rem;">
                        <div style="display:flex; align-items:center; gap:.75rem; margin-bottom:.75rem;">
                            <div style="width:36px; height:36px; border-radius:50%; background:#0f6efd;
                                        display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-size:.9rem;">
                                {{ comment.nameAuthor|slice(0,1)|upper }}
                            </div>
                            <div>
                                <div style="font-weight:700; color:#0b254c; font-size:.9rem;">{{ comment.nameAuthor }}</div>
                                <div style="font-size:.75rem; color:#6c757d;">{{ comment.createdAt|date('d/m/Y à H:i') }}</div>
                            </div>
                        </div>
                        <p style="margin:0; color:#495057; font-size:.9rem; line-height:1.65;">{{ comment.content }}</p>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}

                {# Navigation bas de page #}
                <div style="margin-top:3rem; padding-top:1.5rem; border-top:1px solid #e7eaf3; display:flex; gap:1rem; flex-wrap:wrap;">
                    <a href="{{ path('app_article_index') }}"
                       style="display:inline-flex; align-items:center; gap:.5rem; padding:.65rem 1.25rem;
                              border:1.5px solid #e7eaf3; border-radius:10px; color:#495057; text-decoration:none;
                              font-size:.875rem; font-weight:500;">
                        <i class="bi bi-arrow-left"></i>Tous les articles
                    </a>
                    {% if is_granted('ROLE_WRITER') %}
                    <a href="{{ path('app_article_edit', {id: article.id}) }}"
                       style="display:inline-flex; align-items:center; gap:.5rem; padding:.65rem 1.25rem;
                              background:#0f6efd; color:#fff; border-radius:10px; text-decoration:none;
                              font-size:.875rem; font-weight:600;">
                        <i class="bi bi-pencil"></i>Modifier
                    </a>
                    {% endif %}
                </div>
            </div>

            {# Sidebar #}
            <aside class="col-lg-3 offset-lg-1 d-none d-lg-block">
                <div style="position:sticky; top:90px;">

                    {# Infos article #}
                    <div style="background:#fff; border:1px solid #e7eaf3; border-radius:14px; padding:1.5rem; margin-bottom:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,.04);">
                        <h4 style="font-size:.78rem; font-weight:700; color:#0f6efd; text-transform:uppercase; letter-spacing:.08em; margin-bottom:1rem;">
                            Informations
                        </h4>
                        <div style="font-size:.85rem; color:#495057; display:flex; flex-direction:column; gap:.6rem;">
                            <div><i class="bi bi-calendar3 me-2 text-muted"></i>{{ article.createdAt|date('d/m/Y') }}</div>
                            {% if article.category %}
                            <div><i class="bi bi-folder me-2 text-muted"></i>{{ article.category.name }}</div>
                            {% endif %}
                            {% if article.author %}
                            <div><i class="bi bi-person me-2 text-muted"></i>{{ article.author.firstname ?? article.author.email }}</div>
                            {% endif %}
                        </div>
                    </div>

                    {# Tags sidebar #}
                    {% if article.tags is not empty %}
                    <div style="background:#fff; border:1px solid #e7eaf3; border-radius:14px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,.04);">
                        <h4 style="font-size:.78rem; font-weight:700; color:#0f6efd; text-transform:uppercase; letter-spacing:.08em; margin-bottom:1rem;">
                            Tags
                        </h4>
                        <div style="display:flex; flex-wrap:wrap; gap:.4rem;">
                            {% for tag in article.tags %}
                            <a href="{{ path('app_article_index', {tag: tag.id}) }}"
                               style="font-size:.78rem; padding:.25rem .65rem; background:#f0f4ff; color:#0f6efd;
                                      border-radius:20px; text-decoration:none; border:1px solid #d0e0ff; font-weight:500;">
                                {{ tag.name }}
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>
            </aside>
        </div>
    </div>
</section>

{% endblock %}
