{% extends 'base.html.twig' %}

{% block title %}Pages — {{ site_name|default('MonCMS') }}{% endblock %}
{% block meta_description %}Liste des pages publiées sur le site.{% endblock %}

{% block page_styles %}
.page-hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
}

.page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
}

.page-breadcrumb {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.page-breadcrumb a { color: var(--color-muted); }
.page-breadcrumb a:hover { color: var(--color-ink); }

/* ── Page body ── */
.page-body {
    font-size: 1.05rem;
    line-height: 1.85;
    color: #222;
    max-width: 72ch;
}

.page-body h2 { font-size: 1.6rem; margin-top: 3rem; margin-bottom: 0.75rem; }
.page-body h3 { font-size: 1.25rem; margin-top: 2rem; margin-bottom: 0.5rem; }
.page-body p  { margin-bottom: 1.25rem; }
.page-body ul, .page-body ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
.page-body li { margin-bottom: 0.4rem; }

.page-body a {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--color-ink);
}

.page-body blockquote {
    border-left: 3px solid var(--color-ink);
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    background: var(--color-surface);
    font-family: var(--font-serif);
    font-size: 1.15rem;
}

.page-body img {
    border-radius: var(--radius);
    margin: 1.5rem 0;
    max-width: 100%;
}

/* ── Sous-pages ── */
.child-page-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all var(--transition);
    color: var(--color-ink);
    text-decoration: none;
}

.child-page-link:hover {
    border-color: var(--color-ink);
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    color: var(--color-ink);
}

.child-page-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    margin-bottom: 0;
}
{% endblock %}

{% block body %}
<section class="py-5">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
            <h1 class="mb-0">Toutes les pages</h1>
            {% if is_granted('ROLE_WRITER') %}
            <a href="{{ path('app_page_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Créer une page
            </a>
            {% endif %}
        </div>

        {% if pages is not empty %}
            <div class="row g-4">
                {% for page in pages %}
                    <div class="col-md-6 col-lg-4">
                        <article class="card h-100">
                            <div class="card-body d-flex flex-column">
                                <h3 class="card-title">{{ page.title }}</h3>
                                <p class="card-text text-muted mb-4">{{ page.content|striptags|slice(0, 110) }}…</p>
                                <a href="{{ path('app_page_show', {slug: page.slug}) }}" class="mt-auto btn btn-outline-primary">Voir la page</a>
                                {% if is_granted('ROLE_WRITER') %}
                                <a href="{{ path('app_page_edit', {id: page.id}) }}" class="btn btn-sm btn-outline-secondary mt-2">
                                    <i class="bi bi-pencil"></i> Éditer
                                </a>
                                {% endif %}
                            </div>
                        </article>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="alert alert-info">Aucune page publiée pour le moment.</div>
        {% endif %}
    </div>
</section>

{% endblock %}
