<form method="post" action="{{ path('app_page_delete', {'id': page.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette page ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ page.id) }}">
    <button class="btn btn-outline-danger" type="submit">
        <i class="bi bi-trash"></i> Supprimer la page
    </button>
</form>
